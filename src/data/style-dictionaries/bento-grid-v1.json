{
  "id": "bento-grid-v1",
  "paradigm": "bento-grid",
  "rules": {
    "layout": {
      "section_padding": "py-16 md:py-24",
      "max_width": "max-w-7xl mx-auto",
      "columns_max": 4,
      "overlaps_allowed": false,
      "negative_margin_allowed": false,
      "full_bleed_allowed": false,
      "section_transition": "flat"
    },
    "typography": {
      "heading_font": "font-display",
      "heading_weight": "font-semibold",
      "heading_size_hero": "text-4xl md:text-6xl",
      "heading_size_section": "text-2xl md:text-3xl",
      "tracking": "tracking-tight",
      "gradient_text_allowed": true,
      "line_height_hero": "leading-[1.1]",
      "line_height_section": "leading-snug",
      "responsive_scale": true
    },
    "color": {
      "base": "mixed",
      "dark_sections_allowed": true,
      "gradient_allowed": true,
      "accent_count_max": 2,
      "section_bg_sequence": [
        "background",
        "surface",
        "dark",
        "background"
      ],
      "bg_animation_mode": "none"
    },
    "animation": {
      "budget": "subtle",
      "keyframes_allowed": false,
      "scroll_driven_allowed": false,
      "text_animations_allowed": [],
      "hover_effects_allowed": [
        "scale"
      ]
    },
    "decoration": {
      "mesh_gradient": false,
      "glassmorphism": false,
      "border_glow": false,
      "geometric_shapes": false,
      "noise_texture": false,
      "color_overlays": true,
      "diagonal_cuts": false,
      "concave_sections": false
    }
  },
  "forbidden_patterns": [
    "uniform grid — alle Tiles gleich groß (verboten — mind. 3 verschiedene Tile-Größen)",
    "border-radius kleiner als rounded-2xl (alle Tiles: rounded-2xl oder rounded-3xl)",
    "Tailwind shadow-* auf Tiles (kein shadow-md, shadow-lg — kein Box-Shadow auf Tiles)",
    "border auf Tiles (kein border-* — Tiefenwirkung durch Hintergrundfarben-Kontrast)",
    "volle Textblöcke über gesamte Breite (max col-span-2 für Text-Tiles)",
    "min-h-screen ohne md: prefix",
    "alle Tiles mit gleicher Hintergrundfarbe (jede Tile MUSS eigene bg bekommen)"
  ],
  "required_patterns": [
    "CSS Grid: grid-cols-1 md:grid-cols-4 gap-3 auto-rows-[minmax(200px,auto)]",
    "mindestens 1 Hero-Tile: md:col-span-2 md:row-span-2 (primäre Message oder Metrik)",
    "mindestens 1 Wide-Tile: md:col-span-2 row-span-1 (sekundäres Feature)",
    "mindestens 2 Small-Tiles: col-span-1 row-span-1 (einzelne Stats, Icons, Microcopy)",
    "jede Tile: eigene Hintergrundfarbe — abwechseln zwischen surface/dark/primary/accent/background",
    "Tile-Inhalt: flex flex-col justify-between — Label oben, Stat/CTA unten verankert",
    "mindestens 1 Image-Tile: Bild füllt Tile vollständig (object-cover absolute inset-0)",
    "alle Tiles: rounded-2xl overflow-hidden p-6 oder p-8"
  ],
  "html_patterns": {
    "section_wrapper": "<section class=\"relative py-16 md:py-24\" style=\"background-color: var(--color-background)\">",
    "container": "<div class=\"max-w-7xl mx-auto px-4 md:px-8\">",
    "bento_grid": "<div class=\"grid grid-cols-1 md:grid-cols-4 gap-3 auto-rows-[minmax(200px,auto)]\">",
    "bento_tile_hero": "<div class=\"md:col-span-2 md:row-span-2 rounded-2xl p-8 flex flex-col justify-between overflow-hidden relative\" style=\"background-color: var(--color-dark)\">",
    "bento_tile_wide": "<div class=\"md:col-span-2 rounded-2xl p-6 flex flex-col justify-between overflow-hidden relative\" style=\"background-color: var(--color-surface)\">",
    "bento_tile_small_dark": "<div class=\"rounded-2xl p-6 flex flex-col justify-between overflow-hidden relative\" style=\"background-color: var(--color-primary)\">",
    "bento_tile_small_light": "<div class=\"rounded-2xl p-6 flex flex-col justify-between overflow-hidden relative\" style=\"background-color: var(--color-surface)\">",
    "bento_tile_image": "<div class=\"md:col-span-1 rounded-2xl overflow-hidden relative\" style=\"min-height: 200px\"><img src=\"https://picsum.photos/600/400?random=1\" alt=\"\" class=\"absolute inset-0 w-full h-full object-cover\"><div class=\"absolute inset-0 p-5 flex flex-col justify-end\" style=\"background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 60%)\">",
    "bento_stat": "<div class=\"font-display font-bold tracking-tight leading-none\" style=\"font-size: clamp(2rem,5vw,3.5rem); color: var(--color-accent)\">",
    "bento_label": "<p class=\"text-xs font-semibold tracking-[0.12em] uppercase mb-3\" style=\"color: var(--color-text-muted)\">",
    "eyebrow": "<div class=\"text-[.68rem] font-semibold tracking-[.14em] uppercase mb-4\" style=\"color: var(--color-accent)\">LABEL</div>",
    "hero_h1": "<h1 class=\"font-display font-semibold text-4xl md:text-6xl tracking-tight leading-[1.05]\">",
    "cta_primary": "<a href=\"#\" class=\"inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded-xl transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]\" style=\"background-color:var(--color-accent);color:#fff\">",
    "cta_secondary": "<a href=\"#\" class=\"inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold rounded-xl border transition-all duration-200 hover:scale-[1.02]\" style=\"border-color:var(--color-accent);color:var(--color-accent)\">",
    "cta_ghost": "<a href=\"#\" class=\"inline-flex items-center gap-2 px-4 py-2.5 text-sm font-medium transition-colors\" style=\"color:var(--color-text-muted)\">",
    "card": "<div class=\"rounded-2xl p-6 flex flex-col justify-between overflow-hidden relative\" style=\"background-color: var(--color-surface)\">",
    "card_hover": "group-hover:scale-[1.015]",
    "card_hover_classes": "transition-transform duration-200 ease-out",
    "card_wrapper": "<div class=\"group cursor-pointer\">"
  },
  "variants": {
    "hero": [
